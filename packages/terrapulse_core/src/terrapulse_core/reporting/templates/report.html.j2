<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <style>
    :root {
      --brand:   #1A6B4A;
      --accent:  #F39C12;
      --danger:  #E74C3C;
      --safe:    #2ECC71;
      --neutral: #95A5A6;
      --text:    #2C3E50;
      --bg:      #FAFAFA;
    }
    body { font-family: "Segoe UI", Arial, sans-serif; color: var(--text); background: var(--bg); margin: 0; padding: 0; }
    header { background: var(--brand); color: #fff; padding: 2rem 3rem; }
    header h1 { margin: 0; font-size: 1.8rem; }
    header p  { margin: 0.3rem 0 0; opacity: 0.85; font-size: 0.95rem; }
    main { padding: 2rem 3rem; }
    section { margin-bottom: 2.5rem; }
    h2 { color: var(--brand); border-bottom: 2px solid var(--brand); padding-bottom: 0.3rem; }
    h3 { color: #555; }
    .kpi-grid { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .kpi-card { background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 1rem 1.5rem; min-width: 160px; flex: 1; }
    .kpi-card .value { font-size: 2rem; font-weight: bold; color: var(--brand); }
    .kpi-card .label { font-size: 0.85rem; color: #777; margin-top: 0.2rem; }
    .narrative { background: #fff; border-left: 4px solid var(--brand); padding: 1rem 1.5rem; border-radius: 0 8px 8px 0; font-size: 1rem; line-height: 1.7; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--brand); color: #fff; padding: 0.6rem 0.8rem; text-align: left; }
    td { padding: 0.5rem 0.8rem; border-bottom: 1px solid #eee; }
    tr:nth-child(even) td { background: #f4f4f4; }
    .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.8rem; font-weight: bold; }
    .badge-high   { background: #fdecea; color: var(--danger); }
    .badge-medium { background: #fef9e7; color: var(--accent); }
    .badge-low    { background: #eafaf1; color: var(--safe); }
    footer { text-align: center; padding: 1.5rem; font-size: 0.8rem; color: #aaa; border-top: 1px solid #eee; }
    .chart-container { background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 1rem; min-height: 300px; }
  </style>
  {% if include_plotly %}
  <script src="https://cdn.plot.ly/plotly-2.30.0.min.js"></script>
  {% endif %}
</head>
<body>

<header>
  <h1>🌍 {{ title }}</h1>
  <p>{{ aoi_description }} &bull; {{ time_window }} &bull; Generated {{ generated_at }}</p>
</header>

<main>

  <!-- KPI summary row -->
  <section>
    <h2>Key Findings</h2>
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="value">{{ n_scenes }}</div>
        <div class="label">Sentinel-1 scenes</div>
      </div>
      <div class="kpi-card">
        <div class="value">{{ "%.1f"|format(max_subsidence_mm_yr|abs) }}</div>
        <div class="label">Max rate (mm/yr)</div>
      </div>
      <div class="kpi-card">
        <div class="value">{{ dominant_class }}</div>
        <div class="label">Dominant pattern</div>
      </div>
      <div class="kpi-card">
        <div class="value">{{ n_high_risk_assets }}</div>
        <div class="label">High-risk assets</div>
      </div>
      <div class="kpi-card">
        <div class="value">{{ "%.2f"|format(mean_coherence) }}</div>
        <div class="label">Mean coherence</div>
      </div>
    </div>
  </section>

  <!-- AI / templated narrative -->
  <section>
    <h2>Summary</h2>
    <div class="narrative">{{ summary_text }}</div>
  </section>

  <!-- Velocity map image -->
  {% if velocity_image_b64 %}
  <section>
    <h2>LOS Velocity Map</h2>
    <img src="data:image/png;base64,{{ velocity_image_b64 }}"
         alt="LOS velocity map"
         style="max-width:100%; border-radius:8px; border:1px solid #ddd;">
  </section>
  {% endif %}

  <!-- Interactive time-series chart placeholder -->
  {% if include_plotly %}
  <section>
    <h2>Deformation Time Series</h2>
    <div id="ts-chart" class="chart-container"></div>
    <script>
      var tsData = {{ plotly_ts_json | safe }};
      Plotly.newPlot("ts-chart", tsData.data, tsData.layout, {responsive: true});
    </script>
  </section>
  {% endif %}

  <!-- At-risk assets table -->
  <section>
    <h2>Infrastructure at Risk (Top 20)</h2>
    <table>
      <thead>
        <tr>
          <th>Asset</th>
          <th>Type</th>
          <th>Mean velocity (mm/yr)</th>
          <th>Deformation class</th>
          <th>Risk</th>
        </tr>
      </thead>
      <tbody>
        {% for asset in top_assets %}
        <tr>
          <td>{{ asset.name }}</td>
          <td>{{ asset.asset_type }}</td>
          <td>{{ "%.1f"|format(asset.mean_velocity) }}</td>
          <td>{{ asset.deformation_class }}</td>
          <td>
            {% if asset.risk_score > 7 %}
              <span class="badge badge-high">High</span>
            {% elif asset.risk_score > 4 %}
              <span class="badge badge-medium">Medium</span>
            {% else %}
              <span class="badge badge-low">Low</span>
            {% endif %}
          </td>
        </tr>
        {% else %}
        <tr><td colspan="5" style="text-align:center;color:#aaa;">No assets found in AOI</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <!-- Recommendations -->
  <section>
    <h2>Recommendations</h2>
    <div class="narrative">{{ recommendations_text }}</div>
  </section>

  <!-- Provenance -->
  <section>
    <h2>Processing Provenance</h2>
    <table>
      <tr><th>Run ID</th><td><code>{{ run_id }}</code></td></tr>
      <tr><th>Engine</th><td>{{ engine_name }} ({{ processing_mode }} mode)</td></tr>
      <tr><th>TerraPulse version</th><td>{{ terrapulse_version }}</td></tr>
      <tr><th>Scenes</th><td>{{ n_scenes }} Sentinel-1 SLC acquisitions</td></tr>
      <tr><th>Recipe</th><td><a href="{{ recipe_path }}">{{ recipe_path }}</a></td></tr>
    </table>
  </section>

</main>

<footer>
  Generated by <strong>TerraPulse {{ terrapulse_version }}</strong> &bull;
  Data: ESA Sentinel-1 / Copernicus Programme &bull;
  Processing: {{ engine_name }} &bull;
  GPL-3.0
</footer>

</body>
</html>
